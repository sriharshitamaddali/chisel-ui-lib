{
    "compilerOptions": {
        "target": "es6",
        "module": "esnext",
        "jsx": "react-jsx",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "moduleResolution": "bundler",
        "declarationDir": "dist",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "src/declarations.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.stories.tsx",
        "**/*.test.tsx"
    ]
}